PORT=3000

# Use either DATABASE_URL or the PG* values below.
# Example:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/tiny_guestbook
DATABASE_URL=

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=tiny_guestbook

# Set this to true when your hosted database requires SSL.
DB_SSL=false
